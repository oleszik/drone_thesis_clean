{
  "name": "drone-thesis-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Electron desktop shell for the Drone Thesis dashboard.",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^36.9.5",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.oleszik.drone-thesis",
    "productName": "Drone Thesis Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../quad_rl",
        "to": "quad_rl",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../requirements.txt",
        "to": "requirements.txt"
      },
      {
        "from": "../backend/requirements.txt",
        "to": "backend-requirements.txt"
      },
      {
        "from": "../pyproject.toml",
        "to": "pyproject.toml"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Science"
    }
  }
}
